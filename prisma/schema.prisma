generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER 
  ADMIN
}

enum BlogCategory {
MATCH
PLAYER
TRANSFER
NEWS
FANS
HISTORY
TRAINING
EVENT
MERCH
}

model User {
  id String @id @default(uuid())
  email String @unique
  firstName String @map("first_name")
  lastName String  @map("last_name")
  password String
  role UserRole
  posts Blog[]
  refreshToken RefreshToken[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([id, email])
}

model Blog {
  id String @id @default(uuid())
  image String
  imagePublicId String
  title String @unique
  slug String @unique
  excerpt String
  content String
  category BlogCategory
  isPublished Boolean @default(false) @map("is_published")
  author User @relation(fields: [authorId], references: [id])
  authorId String @map("author_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  @@index([id, slug])
}


model RefreshToken {
  id String @id @default(uuid())
  hashedToken String @unique @map("hashed_token")
  user User @relation(fields: [userId], references: [id])
  userId String @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now())
}

model ContactForm {
  id String @id @default(uuid())
  email String
  message String
  isResponded Boolean @default(false)
  createdAt DateTime @default(now())
}


enum PlayerPosition {
  GOAL_KEEPER
  DEFENDER
  MIDFIELDER
  ATTACKER
}

model Players {
  id String @id @default(uuid())
  fullName String @map("full_name")
  jerseyNumber Int @unique @map("jersey_number")
  nationality String
  position PlayerPosition
  avatar String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
}

enum StaffRole {    
  MANAGER
  HEAD_COACH
  ASSISTANT_COACH
  GOALKEEPER_COACH
  FITNESS_COACH
  PHYSIOTHERAPIST
  TEAM_DOCTOR
  ANALYST
  KIT_MANAGER
  ADMINISTRATOR
}

model Staff {
  id String @id @default(uuid())
  fullName String @map("full_name")
  nationality String
  staffRole StaffRole @map("staff_role")
  avatar String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
}