<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reset Your Password</title>
  </head>
  <body
    style="
      margin: 0;
      padding: 0;
      font-family: Arial, sans-serif;
      background-color: #f6f8f4;
      color: #2f3a2f;
    "
  >
    <table
      role="presentation"
      width="100%"
      cellspacing="0"
      cellpadding="0"
      style="background-color: #f6f8f4; padding: 40px 20px"
    >
      <tr>
        <td align="center">
          <table
            role="presentation"
            width="100%"
            cellspacing="0"
            cellpadding="0"
            style="
              max-width: 600px;
              background-color: #ffffff;
              border-radius: 12px;
              overflow: hidden;
              box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
            "
          >
            <tr>
              <td
                style="
                  background: linear-gradient(135deg, #2f6b3b, #f28c28);
                  padding: 32px 24px;
                  text-align: center;
                  color: #ffffff;
                "
              >
                <h1 style="margin: 0; font-size: 28px">Reset Your Password</h1>
              </td>
            </tr>

            <tr>
              <td style="padding: 40px 32px">
                <h2
                  style="
                    margin: 0 0 16px;
                    font-size: 24px;
                    color: #2f6b3b;
                  "
                >
                  Hi
                  {{name}},
                </h2>

                <p
                  style="
                    margin: 0 0 16px;
                    font-size: 16px;
                    line-height: 1.6;
                    color: #4f5f4f;
                  "
                >
                  We received a request to reset your MATCHPASS password.
                </p>

                <p
                  style="
                    margin: 0 0 24px;
                    font-size: 16px;
                    line-height: 1.6;
                    color: #4f5f4f;
                  "
                >
                  Click the button below to create a new password and regain
                  access to your account.
                </p>

                <a
                  href="{{url}}"
                  style="
                    display: inline-block;
                    padding: 14px 24px;
                    background-color: #f28c28;
                    color: #ffffff;
                    text-decoration: none;
                    border-radius: 8px;
                    font-size: 16px;
                    font-weight: bold;
                  "
                >
                  Reset Password
                </a>

                <p
                  style="
                    margin: 24px 0 0;
                    font-size: 14px;
                    line-height: 1.6;
                    color: #6b776b;
                  "
                >
                  If you did not request a password reset, you can safely ignore
                  this email.
                </p>
              </td>
            </tr>

            <tr>
              <td
                style="
                  padding: 24px 32px;
                  background-color: #eef5ea;
                  font-size: 14px;
                  color: #5d6b5d;
                  text-align: center;
                  border-top: 1px solid #dbe7d5;
                "
              >
                <p style="margin: 0">
                  For your security, this password reset link may expire after a
                  limited time.
                </p>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>