<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Verify your email - MATCHPASS</title>
  </head>
  <body
    style="
      margin: 0;
      padding: 0;
      background-color: rgb(245, 247, 244);
      font-family: Arial, sans-serif;
      color: rgb(20, 29, 22);
    "
  >
    <table
      role="presentation"
      width="100%"
      cellspacing="0"
      cellpadding="0"
      style="background-color: rgb(245, 247, 244); padding: 40px 20px"
    >
      <tr>
        <td align="center">
          <table
            role="presentation"
            width="100%"
            cellspacing="0"
            cellpadding="0"
            style="
              max-width: 600px;
              background-color: rgb(255, 255, 255);
              border: 1px solid rgb(214, 224, 216);
              border-radius: 16px;
              overflow: hidden;
              box-shadow: 0 8px 24px rgba(20, 29, 22, 0.06);
            "
          >
            <tr>
              <td
                style="
                  padding: 32px 32px 24px;
                  border-bottom: 1px solid rgb(214, 224, 216);
                  text-align: left;
                "
              >
                <p
                  style="
                    margin: 0 0 8px;
                    font-size: 13px;
                    letter-spacing: 1px;
                    text-transform: uppercase;
                    color: rgb(92, 105, 95);
                    font-weight: 700;
                  "
                >
                  MATCHPASS
                </p>
                <h1
                  style="
                    margin: 0;
                    font-size: 28px;
                    line-height: 1.25;
                    font-weight: 700;
                    color: rgb(20, 29, 22);
                  "
                >
                  Verify your email address
                </h1>
              </td>
            </tr>

            <tr>
              <td style="padding: 36px 32px 32px">
                <h2
                  style="
                    margin: 0 0 18px;
                    font-size: 22px;
                    line-height: 1.3;
                    color: rgb(20, 29, 22);
                    font-weight: 700;
                  "
                >
                  Hi
                  {{name}},
                </h2>

                <p
                  style="
                    margin: 0 0 16px;
                    font-size: 16px;
                    line-height: 1.7;
                    color: rgb(92, 105, 95);
                  "
                >
                  Thank you for registering with MATCHPASS. To complete your
                  account setup, please verify your email address.
                </p>

                <p
                  style="
                    margin: 0 0 24px;
                    font-size: 16px;
                    line-height: 1.7;
                    color: rgb(92, 105, 95);
                  "
                >
                  Once your email is verified, your account will be fully
                  activated and ready to access MATCHPASS features.
                </p>

                <table
                  role="presentation"
                  cellspacing="0"
                  cellpadding="0"
                  style="margin: 0 0 28px"
                >
                  <tr>
                    <td align="center">
                      <a
                        href="{{url}}"
                        style="
                          display: inline-block;
                          padding: 14px 24px;
                          background-color: rgb(210, 82, 32);
                          color: rgb(255, 248, 244);
                          text-decoration: none;
                          border-radius: 10px;
                          font-size: 15px;
                          font-weight: 700;
                        "
                      >
                        Verify email
                      </a>
                    </td>
                  </tr>
                </table>

                <table
                  role="presentation"
                  width="100%"
                  cellspacing="0"
                  cellpadding="0"
                  style="
                    background-color: rgb(236, 241, 236);
                    border: 1px solid rgb(214, 224, 216);
                    border-radius: 12px;
                  "
                >
                  <tr>
                    <td style="padding: 18px">
                      <p
                        style="
                          margin: 0 0 8px;
                          font-size: 14px;
                          line-height: 1.5;
                          color: rgb(20, 29, 22);
                          font-weight: 700;
                        "
                      >
                        Referral note
                      </p>
                      <p
                        style="
                          margin: 0;
                          font-size: 14px;
                          line-height: 1.7;
                          color: rgb(92, 105, 95);
                        "
                      >
                        If you registered using a referral code, its benefits
                        will only be applied after your account has been
                        successfully verified.
                      </p>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <tr>
              <td
                style="
                  padding: 20px 32px;
                  border-top: 1px solid rgb(214, 224, 216);
                  background-color: rgb(255, 255, 255);
                  text-align: center;
                "
              >
                <p
                  style="
                    margin: 0;
                    font-size: 13px;
                    line-height: 1.6;
                    color: rgb(92, 105, 95);
                  "
                >
                  If you did not create a MATCHPASS account, you can safely
                  ignore this email.
                </p>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>